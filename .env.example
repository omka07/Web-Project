# Copy to `.env` and adjust. Unset variables fall back to safe dev defaults
# in myproject/settings.py, so local `runserver` works without this file.

# Django
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# CORS — comma-separated origins allowed to call the API
CORS_ALLOWED_ORIGINS=http://localhost:4200,http://127.0.0.1:4200

# Database. Leave blank to use the local SQLite file.
# For Postgres (e.g. under docker-compose):
#   DATABASE_URL=postgres://quizroom:quizroom@db:5432/quizroom
DATABASE_URL=
